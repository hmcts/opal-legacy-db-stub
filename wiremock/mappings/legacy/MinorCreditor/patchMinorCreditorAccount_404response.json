{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPathPattern": "/opal",
    "queryParameters": {
      "actionType": {
        "equalTo": "LIBRA.of_update_minor_creditor_account"
      }
    },
    "bodyPatterns": [ {
      "matchesJsonPath": "$[?(@.creditor_account_id == '404')]"
    } ]
  },
  "response": {
    "status": 404,
    "headers": {
      "Content-Type": "application/xml"
    },
    "body": "<error><message>Minor creditor account not found</message></error>"
  }
}
