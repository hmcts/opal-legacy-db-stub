{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPathPattern": "/opal",
    "queryParameters": {
      "actionType": {
        "equalTo": "LIBRA.of_update_minor_creditor_account"
      }
    },
    "bodyPatterns": [ {
      "matchesJsonPath": "$[?(@.creditor_account_id == '503')]"
    } ]
  },
  "response": {
    "status": 503,
    "headers": {
      "Content-Type": "text/plain"
    },
    "body": "Legacy minor creditor update unavailable"
  }
}
