{
  "request": {
    "method": "POST",
    "urlPathPattern": "/opal",
    "queryParameters": {
      "actionType": {
        "equalTo": "LIBRA.of_update_minor_creditor_account"
      }
    },
    "bodyPatterns": [ {
      "matchesJsonPath": "$[?(@.creditor_account_id == '607')]"
    } ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/xml"
    },
    "bodyFileName": "legacy/MinorCreditor/patchMinorCreditorAccount.xml"
  }
}
